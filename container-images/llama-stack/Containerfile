FROM quay.io/fedora/fedora:43

ARG RAMALAMA_STACK_VERSION=0.2.6
COPY ramalama_stack-0.2.6.dev* /

RUN dnf -y install uv gcc python3-devel && \
    dnf -y clean all

RUN --mount=type=cache,target=/root/.cache/uv \
    uv venv && \
    uv pip install ramalama_stack-${RAMALAMA_STACK_VERSION}.dev26.tar.gz

COPY --chmod=755 entrypoint.sh /usr/bin/entrypoint.sh

ENTRYPOINT [ "/usr/bin/entrypoint.sh" ]

CMD [ "llama",  "stack",  "run", "--image-type", "venv", "/root/.llama/distributions/ramalama/ramalama-run.yaml" ]
